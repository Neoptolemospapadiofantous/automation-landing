# =============================================================================
# Flowstack landing — environment variables
# =============================================================================
#
# Copy to `.env.local` for local dev:
#   cp .env.example .env.local
#
# For production (Laravel Forge), set these in
#   Forge → Site → Environment.
# See docs/deploy-forge.md §7 for the full Forge setup including the runtime
# vars (NODE_ENV, HOSTNAME, PORT) which the daemon sets, not this file.
# =============================================================================


# ─── Site identity ─────────────────────────────────────────────────────────────

# Public canonical URL of this site. Cascades into:
#   - <link rel="canonical">           (every page)
#   - sitemap.xml + robots.txt
#   - Open Graph / Twitter image URLs
#   - JSON-LD Organization / WebSite / SoftwareApplication @ids
#
# Without this set, everything advertises https://flowstack.example
# (the placeholder fallback in src/lib/seo.ts).
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─── Dashboard linkage ────────────────────────────────────────────────────────

# URL of the Laravel dashboard exposing /api/public/stats.
# SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix) — the marketing site fetches
# from this on the server and Next ISR caches the result for 5 minutes.
# The stats-broadcaster singleton polls every 5s for the SSE stream.
#
# Local dev:        http://localhost:8000
# Same-Forge-box:   http://127.0.0.1:8000
# Separate host:    https://app.flowstack.example
DASHBOARD_API_URL=http://localhost:8000

# Visitor-facing dashboard origin. Shipped to the browser (NEXT_PUBLIC_*)
# so "Try it for $99", Login, and Register buttons can target the real
# app origin. Same value as DASHBOARD_API_URL in nearly every deployment,
# except when the dashboard is on a public domain different from the
# server-internal hostname.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:8000


# ─── Analytics (optional) ─────────────────────────────────────────────────────

# Google Analytics 4 Measurement ID. Format: G-XXXXXXXXXX.
#
# When unset, ALL analytics rendering is skipped: no script tag, no
# cookie banner, no Consent Mode init, no gtag. The site stays
# tracking-free — perfect for dev, preview, and pre-launch.
#
# Once set, Consent Mode v2 still gates the actual data collection
# behind the visitor's explicit consent (denied by default until they
# click Accept on the banner).
#
# Create the property at https://analytics.google.com/ → Admin →
# Data Streams → Web → Measurement ID.
# NEXT_PUBLIC_GA_ID=


# ─── Audit-form email delivery (Zoho SMTP) ────────────────────────────────────

# Server-only SMTP credentials used by src/lib/mail.ts to send audit-form
# submissions (the only form on the site) to the operator inbox.
#
# When ANY of these is unset, the server action falls back to console.log
# only and the visitor still sees the success message — so dev / preview
# deploys don't break. In production, all of them must be set or audit
# submissions silently go nowhere.
#
# Zoho EU region:
#   SMTP_HOST=smtp.zoho.eu
#   SMTP_PORT=465                  (implicit TLS — use 587 for STARTTLS)
#   SMTP_USER=hello@flowstack.run  (the authenticated mailbox)
#   SMTP_PASS=<app password>       (generated in Zoho → Security → App
#                                   Passwords; NOT your account password)
#
# SMTP_FROM defaults to SMTP_USER. Override if you want a different
# visible "From" address (must be an alias of SMTP_USER on Zoho's side).
#
# AUDIT_RECIPIENT defaults to hello@flowstack.run. Override to route
# audit submissions to a different inbox without touching code.
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# AUDIT_RECIPIENT=
